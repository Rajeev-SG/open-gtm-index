{
  "name": "open-gtm-index",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 3000",
    "data:build": "node scripts/build-data.mjs",
    "build": "pnpm data:build && vite build",
    "start": "node .output/server/index.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "validate": "pnpm data:build && pnpm typecheck && pnpm test && vite build"
  },
  "dependencies": {
    "@fontsource-variable/instrument-sans": "latest",
    "@fontsource-variable/newsreader": "latest",
    "@tanstack/react-router": "1.170.18",
    "@tanstack/react-start": "1.168.28",
    "nitro": "3.0.260610-beta",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "latest",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
